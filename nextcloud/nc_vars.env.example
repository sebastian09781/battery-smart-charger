# Variables de entorno para Nextcloud en Termux
# Copia este archivo como nc_vars.env y completa con tus datos

ACCOUNT_ID="CHANGE_ME"                    # ID de cuenta Cloudflare
CF_TOKEN=CHANGE_ME                         # Token de Cloudflare
WORKER_NAME="nextcloud"                    # Nombre del worker
PUBLIC_URL="https://nextcloud.tudominio.workers.dev"
DATA_DIR="/data/data/com.termux/files/home"
NC_DIR="/storage/emulated/0/Nextcloud/html"
DB_NAME="nextcloud"
DB_USER="ncuser"
DB_PASS="CHANGE_ME"
ADMIN_PASS="CHANGE_ME"
